# Copy this file to `.env` in the same folder and fill in your own values.
# `.env` is gitignored — never commit real secrets.

# REQUIRED: long random string. Must match WHATSAPP_BRIDGE_API_KEY in Lovable secrets.
BRIDGE_API_KEY=replace-with-a-long-random-string

# Optional: HTTP port the bridge listens on. Keep 3000 to match `ngrok http 3000`.
PORT=3000

# Optional: where the scanned WhatsApp session is saved. Survives restarts.
SESSION_PATH=./wweb-session